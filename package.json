{
	"name": "cursor-utils",
	"displayName": "Cursor Utils",
	"description": "Utilities extending experience of working with multiple cursors.",
	"author": {
		"name": "ScheiBig (Marcin Jeznach)"
	},
	"publisher": "ScheiBig",
	"version": "1.0.0",
	"repository": {
		"url": "https://github.com/ScheiBig-Productions/Cursor-Utils",
		"type": "git"
	},
	"license": "GPL-3.0",
	"private": true,
	"icon": "img/icon/icon.png",
	"engines": {
		"vscode": "^1.80.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "cursor-utils.repeatLine",
				"title": "Cursor Utils: Repeat line"
			},
			{
				"command": "cursor-utils.generateNumbers",
				"title": "Cursor Utils: Generate numbers"
			},
			{
				"command": "cursor-utils.alignCursors",
				"title": "Cursor Utils: Align cursors"
			},
			{
				"command": "cursor-utils.realignSelections",
				"title": "Cursor Utils: Realign selections"
			},
			{
				"command": "cursor-utils.padSelections",
				"title": "Cursor Utils: Pad selections"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint \"**/{src,lib,test,examples,scripts,dtslint}/**/*.{ts,mjs}\"",
		"lint-fix": "eslint --fix \"**/{src,lib,test,examples,scripts,dtslint}/**/*.{ts,mjs}\"",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.1",
		"@eslint/eslintrc": "^3.3.1",
		"@eslint/js": "^9.32.0",
		"@stylistic/eslint-plugin": "^5.2.2",
		"@types/mocha": "^10.0.9",
		"@types/node": "20.x",
		"@types/vscode": "^1.80.0",
		"@typescript-eslint/eslint-plugin": "^8.38.0",
		"@typescript-eslint/parser": "^8.38.0",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.4.1",
		"esbuild": "^0.24.0",
		"eslint": "^9.32.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-codegen": "^0.33.0",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-sort-destructure-keys": "^2.0.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.38.0"
	}
}
